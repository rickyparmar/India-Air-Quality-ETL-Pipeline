# ==============================================================================
# Environment Configuration Template for India Air Quality Index ETL Pipeline
# ==============================================================================
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit the '.env' file to version control.

# Data.gov.in API Configuration
# Get your API key from: https://data.gov.in/
API_KEY=your_api_key_here

# Toggle to 'true' to generate high-quality mock data when offline or API is down
USE_MOCK_DATA=false

# Airflow Metadata DB configuration (internal PostgreSQL)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_secure_password_123
AIRFLOW_DB_NAME=airflow

# Analytics DB configuration (target PostgreSQL for analytical database)
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=analytics_secure_password_123
ANALYTICS_DB_NAME=air_quality
ANALYTICS_DB_HOST=analytics-db
ANALYTICS_DB_PORT=5432

# Ports exposed to the host machine
ANALYTICS_DB_EXPOSED_PORT=5432
AIRFLOW_WEBSERVER_EXPOSED_PORT=8080

# Airflow standard credentials (for local dev UI access)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin_password
